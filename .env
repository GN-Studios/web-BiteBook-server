PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/bitebook


# JWT (generate base64: `openssl rand -base64 32`)
JWT_ISSUER=your-app
JWT_AUDIENCE=your-web
JWT_ACCESS_TOKEN_TTL=900s
JWT_ACCESS_SECRET=BASE64_32_BYTES_MIN

JWT_REFRESH_TOKEN_TTL=30d
JWT_REFRESH_SECRET=BASE64_32_BYTES_MIN

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false       # true in production over HTTPS

# Google Sign-In
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
